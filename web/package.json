{
  "name": "awbrn-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "cf-typegen": "wrangler types worker-configuration.d.ts --env-interface CloudflareBindings",
    "db:generate-do": "drizzle-kit generate --config drizzle-do.config.ts",
    "dev": "vite dev",
    "build": "pnpm run cf-typegen && vite build && tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@fontsource/nunito": "5.2.7",
    "@fontsource/press-start-2p": "5.2.7",
    "@stylexjs/stylex": "0.18.2",
    "@tanstack/react-router": "1.168.10",
    "@tanstack/react-start": "1.167.16",
    "better-auth": "1.5.6",
    "comlink": "4.4.2",
    "drizzle-orm": "0.45.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "4.3.6",
    "zustand": "5.0.10"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.29.0",
    "@stylexjs/unplugin": "0.18.2",
    "@types/node": "catalog:",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "drizzle-kit": "0.31.10",
    "typescript": "catalog:",
    "vite": "8.0.1",
    "vitest": "4.1.2",
    "wrangler": "4.74.0"
  }
}
